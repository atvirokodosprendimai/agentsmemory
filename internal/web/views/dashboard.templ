package views

import "strconv"

// DashboardPage lists the user's projects and offers the "create free project"
// control. The create flow is datastar-driven: the button posts the bound
// projectName signal to /projects, and the server streams back patched
// fragments for #flash (the one-time key) and #projects (the refreshed list).
templ DashboardPage(d DashboardData) {
	@Layout("Projects", d.UserEmail) {
		<section class="page-head">
			<p class="eyebrow">Dashboard</p>
			<h1>Your projects</h1>
			<p>Each project is an isolated memory workspace your agents reach over MCP with a bearer token.</p>
			if d.IsSuperAdmin {
				// Platform control, shown only to superadmins: edit the global am_skillset
				// playbook every workspace's agents wake up with.
				<p class="meta-row">
					<a class="link-arrow" href="/superadmin/skillset">
						Edit the global wakeup skillset
						<span aria-hidden="true">→</span>
					</a>
				</p>
			}
		</section>
		@Flash(d.Flash)
		<div class="card create" data-signals="{projectName: ''}">
			<div class="field">
				<label for="projectName">New free project</label>
				<input
					class="input"
					id="projectName"
					data-bind:project-name
					placeholder="e.g. acme-research"
					data-on:keydown="evt.key === 'Enter' && @post('/projects')"
				/>
			</div>
			<button
				class="btn btn-primary"
				data-on:click="@post('/projects')"
				data-indicator:creating
				data-attr:disabled="$creating"
			>
				<span data-show="!$creating">Create free project</span>
				<span class="spinner" data-show="$creating" style="display:none" aria-hidden="true"></span>
			</button>
		</div>
		@ProjectsList(d.Projects)
	}
}

// ProjectsList renders the project grid or an empty state. Its root carries the
// stable id="projects" so datastar's PatchElements can morph it on creation —
// the patched fragment must carry the target id itself, not a wrapper.
templ ProjectsList(projects []ProjectVM) {
	<div id="projects">
		if len(projects) == 0 {
			<div class="card empty">
				<h3>No projects yet</h3>
				<p>Create your first free project to get an MCP endpoint and an API key.</p>
			</div>
		} else {
			<div class="grid">
				for _, p := range projects {
					@ProjectCard(p)
				}
			</div>
		}
	</div>
}

// ProjectCard shows one project: its plan badge, API key (revealed once on
// creation, masked thereafter), and the monthly request usage bar.
templ ProjectCard(p ProjectVM) {
	<article class="project card">
		<div class="project-top">
			<div>
				<h3>{ p.Name }</h3>
				<div class="slug">{ p.Slug }</div>
			</div>
			<span class="badge">{ p.PlanName }</span>
		</div>
		@KeyBlock(KeyVM{TeamID: p.TeamID, CanReveal: p.CanReveal})
		<div>
			<div class="usage-head">
				<span class="kv" style="margin:0">Requests this month</span>
				<span class="nums">{ strconv.Itoa(p.Used) } / { capLabel(p) }</span>
			</div>
			<div class={ barClass(p) }>
				<span
					style={ "width:" + strconv.Itoa(p.Pct) + "%" }
					role="progressbar"
					aria-label="Monthly request usage"
					aria-valuenow={ strconv.Itoa(p.Used) }
					aria-valuemin="0"
					aria-valuemax={ strconv.Itoa(p.Cap) }
				></span>
			</div>
		</div>
		<div class="project-foot">
			<a class="link-arrow" href={ templ.SafeURL("/projects/" + p.TeamID) }>
				Manage skills
				<span aria-hidden="true">→</span>
			</a>
		</div>
	</article>
}

// KeyBlock renders a project's API key area as a datastar morph target
// (id "key-<TeamID>"). It starts masked; an admin's Reveal button fetches the
// decrypted secret into the revealed state (Copy + Hide), and Hide re-masks —
// both via the server so one fragment owns the markup. Members see only the
// masked state (no Reveal control), and the server refuses a reveal for them
// regardless of the UI. No data-indicator here on purpose: datastar signals are
// global, so a shared "revealing" signal would spin every card's button at once.
templ KeyBlock(k KeyVM) {
	<div id={ "key-" + k.TeamID } class="keybox">
		<div class="kv">API key</div>
		if k.Revealed {
			<code class="token">{ k.Secret }</code>
			if k.Rotated {
				<div class="key-note" role="status">Key rotated — the previous key was revoked and has stopped working. Copy the new one now.</div>
			}
			<div class="key-actions">
				<button class="btn btn-ghost btn-sm" type="button" data-on:click={ copyExpr(k.Secret) }>Copy</button>
				<button class="btn btn-ghost btn-sm" type="button" data-on:click={ "@get('/projects/" + k.TeamID + "/key?reveal=0')" }>Hide</button>
			</div>
			// The revealed token is the bearer /mcp accepts directly, so offer the
			// one-paste `claude mcp add` command right here. Guarded on ServerBase so a
			// reveal that couldn't resolve the origin still shows the key without it.
			if k.ServerBase != "" {
				@MCPAddBlock(k.ServerBase, k.ServerName, k.Secret)
			}
		} else if k.ConfirmRotate {
			<div class="token muted">••••••••••••••••••••••••</div>
			<div class="key-warn" role="alert">
				Rotating issues a new key and <b>revokes the current one</b> — any agent still using the old key will stop working.
			</div>
			<div class="key-actions">
				<button class="btn btn-primary btn-sm" type="button" data-on:click={ "@post('/projects/" + k.TeamID + "/key/rotate')" }>Confirm rotate</button>
				<button class="btn btn-ghost btn-sm" type="button" data-on:click={ "@get('/projects/" + k.TeamID + "/key?reveal=0')" }>Cancel</button>
			</div>
		} else {
			<div class="token muted">••••••••••••••••••••••••</div>
			if k.CanReveal {
				<div class="key-actions">
					<button class="btn btn-ghost btn-sm" type="button" data-on:click={ "@get('/projects/" + k.TeamID + "/key?reveal=1')" }>Reveal</button>
					<button class="btn btn-ghost btn-sm" type="button" data-on:click={ "@get('/projects/" + k.TeamID + "/key?confirm=rotate')" }>Rotate</button>
				</div>
			}
		}
		if k.Error != "" {
			<div class="key-error" role="alert">{ k.Error }</div>
		}
	</div>
}

// Flash renders a transient success or error banner. Its root always carries
// id="flash" (even when empty) so it is a stable datastar morph target —
// patching it with an empty Flash clears any prior message.
templ Flash(f FlashVM) {
	<div id="flash">
		if f.Kind == "success" {
			<div class="flash success" role="status">
				<div class="ttl">{ f.Message }</div>
				if f.ClientKey != "" {
					<div class="kv" style="margin-top:.6rem">OAuth Client ID</div>
					<div class="token">{ f.ClientKey }</div>
				}
				if f.Token != "" {
					<div class="kv" style="margin-top:.6rem">Secret / API key — shown once</div>
					<div class="token">{ f.Token }</div>
				}
				// On creation the token is shown once here, so hand over the matching
				// `claude mcp add` command in the same banner — connect Claude before
				// navigating away loses the secret. Needs both the token and the origin.
				if f.Token != "" && f.ServerBase != "" {
					@MCPAddBlock(f.ServerBase, f.ServerName, f.Token)
				}
			</div>
		} else if f.Kind == "error" {
			<div class="flash error" role="alert">
				<div class="ttl">{ f.Message }</div>
			</div>
		}
	</div>
}

// MCPAddBlock renders the ready-to-run `claude mcp add` command that connects
// Claude Code to this workspace, next to a freshly revealed or freshly minted
// secret. It reuses MigrateCard's copy-a-command idiom (.cmd / .cmd-actions /
// .cmd-hint, the $…Copied feedback) so the two command affordances look identical
// and no new CSS is needed. The token is already visible in the surrounding
// block, so embedding it here and on the clipboard exposes nothing new. The
// _mcpCopied signal is FE-only (the _ prefix keeps it off the wire) and re-inits
// whenever this fragment morphs in; it is shared by any command block shown at
// the same time, so two at once would flash "Copied ✓" together — a harmless
// cosmetic edge, never a correctness one.
templ MCPAddBlock(base, name, token string) {
	<div data-signals="{_mcpCopied: false}">
		<div class="kv" style="margin-top:.7rem">Add to Claude Code</div>
		<pre class="cmd" aria-label="Claude Code MCP add command"><code>{ MCPAddCommand(base, name, token) }</code></pre>
		<div class="cmd-actions">
			<button
				class="btn btn-ghost btn-sm"
				type="button"
				data-on:click={ copyExpr(MCPAddCommand(base, name, token)) + "; $_mcpCopied = true; setTimeout(() => $_mcpCopied = false, 1600)" }
			>
				<span data-show="!$_mcpCopied">Copy command</span>
				<span data-show="$_mcpCopied" style="display:none">Copied ✓</span>
			</button>
			<span class="cmd-hint">
				Registers this workspace in <b>every</b> project (<span class="mono">--scope user</span>) so your agents recall memory over MCP. Drop <span class="mono">--scope user</span> to add it to just the current project.
			</span>
		</div>
	</div>
}
