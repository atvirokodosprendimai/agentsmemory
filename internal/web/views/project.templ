package views

import "strconv"

// ProjectDetailPage is one project's skills workspace: a header, the editor (for
// writers/admins), and the list of centralised skills. All three skill signals
// live on one wrapper so a row's Edit button can seed the editor that binds to
// them — datastar signals are global, but scoping them here documents intent and
// keeps the page self-contained. Members see the read-only note instead of the
// editor; the server still enforces the role, this only hides the controls.
templ ProjectDetailPage(d ProjectDetailData) {
	@Layout(d.Project.Name, d.UserEmail) {
		<nav class="breadcrumb" aria-label="Breadcrumb">
			<a href="/dashboard">← Projects</a>
		</nav>
		<section class="page-head">
			<p class="eyebrow">Project</p>
			<h1>{ d.Project.Name }</h1>
			<p>Centralised skills your agents pull by name over MCP — versioned, shared across the whole workspace.</p>
			<div class="meta-row">
				@SlugChip(d.Project.Slug)
				<span class="badge">{ d.Project.PlanName }</span>
			</div>
		</section>
		@Flash(d.Flash)
		if d.Project.CanUpgrade {
			@UpgradeCard(d.Project)
		} else if d.Project.CanManage {
			@ManageCard(d.Project)
		}
		<div data-signals="{skillName:'', skillDescription:'', skillContent:''}">
			if d.CanWrite {
				@SkillEditor(d.Project.TeamID)
			} else {
				<div class="note" role="note">
					You have read-only access to this workspace. Ask an admin for the
					<b>writer</b> role to add or edit skills.
				</div>
			}
			@SkillsList(d.Project, d.Skills, d.CanWrite)
		</div>
		@MembersBlock(d.Members)
		if d.Share.IsAdmin {
			@IncomingShares(d.Share)
		}
		if d.Share.CanShare {
			@ShareCard(d.Share)
		}
		if d.Merge.CanManage {
			@MergeCard(d.Merge)
		}
		@MigrateCard(d.ServerBase)
		@ExportCard(d.Project.TeamID)
	}
}

// ExportCard is the BDAR/GDPR "download your data" action: it links to the
// per-workspace export endpoint, which streams everything this workspace holds as
// a portable SQLite file. It is the outbound counterpart to MigrateCard's inbound
// import, so it reuses the same .card / .eyebrow / .cmd-actions layout for visual
// symmetry and needs no new CSS. The action is a plain download anchor — a file
// download is ordinary HTTP, not a datastar SSE fragment, so no signals are
// involved; the server redacts credential material before the file leaves.
templ ExportCard(teamID string) {
	<section class="card migrate" aria-labelledby="export-h">
		<p class="eyebrow">Your data</p>
		<h2 id="export-h">Download your data</h2>
		<p class="migrate-lede">
			Export everything this workspace holds — every drawer, diary entry, closet,
			knowledge-graph fact and tunnel, plus your account, membership and API-key
			details — as a single <span class="mono">.sqlite</span> file. It is your right
			under <abbr title="Bendrasis duomenų apsaugos reglamentas — the EU GDPR">BDAR</abbr>
			to take your data with you.
		</p>
		<div class="cmd-actions">
			<a class="btn btn-primary" href={ templ.SafeURL("/projects/" + teamID + "/export") } download>
				Download (.sqlite)
			</a>
			<span class="cmd-hint">
				A standard SQLite database — open it with any SQLite browser. Passwords and
				API-key secrets are redacted. Large workspaces may take a moment.
			</span>
		</div>
	</section>
}

// UpgradeCard is the per-workspace upgrade-to-Pro CTA, shown only to an admin of
// a free-plan workspace when Stripe is configured (gated by ProjectVM.CanUpgrade;
// the server re-checks on POST). It is fully backend-driven: a segmented control
// writes the chosen plan code into the $proInterval signal, the price block reacts
// to it, and Upgrade posts that signal — the handler opens a Stripe Checkout
// session and redirects the browser. The two prices mirror the seeded Pro catalog
// rows (€50 / month, €500 / year = two months free). $upgrading drives the
// in-flight spinner/disabled state so a double-click can't open two sessions.
templ UpgradeCard(p ProjectVM) {
	<section class="card upgrade-card" aria-labelledby="upgrade-h" data-signals="{proInterval:'pro_monthly', upgrading:false}">
		<p class="eyebrow">Plan</p>
		<h2 id="upgrade-h">Upgrade to Pro</h2>
		<p class="upgrade-lede">
			This workspace is on the free plan. Pro lifts the monthly request cap to a
			million and keeps every agent on the team running at full tilt.
		</p>
		<div class="seg" role="group" aria-label="Billing period">
			<button
				type="button"
				class="seg-btn"
				data-class="{active: $proInterval === 'pro_monthly'}"
				data-attr:aria-pressed="$proInterval === 'pro_monthly' ? 'true' : 'false'"
				data-on:click="$proInterval = 'pro_monthly'"
			>Monthly</button>
			<button
				type="button"
				class="seg-btn"
				data-class="{active: $proInterval === 'pro_annual'}"
				data-attr:aria-pressed="$proInterval === 'pro_annual' ? 'true' : 'false'"
				data-on:click="$proInterval = 'pro_annual'"
			>
				Annual
				<span class="seg-save">2 months free</span>
			</button>
		</div>
		<div class="upgrade-price" aria-live="polite">
			<div data-show="$proInterval === 'pro_monthly'">
				<span class="upgrade-amt">€50</span>
				<span class="upgrade-per">/ month</span>
			</div>
			<div data-show="$proInterval === 'pro_annual'" style="display:none">
				<span class="upgrade-amt">€500</span>
				<span class="upgrade-per">/ year</span>
				<span class="upgrade-sub">≈ €41.67 / mo, billed yearly</span>
			</div>
		</div>
		<ul class="upgrade-list">
			<li>1,000,000 metered requests every month</li>
			<li>Everything in Free — unlimited drawers, diary, knowledge graph</li>
			<li>Per-team isolated vector store</li>
		</ul>
		<div class="upgrade-actions">
			<button
				class="btn btn-primary"
				data-on:click={ "@post('/projects/" + p.TeamID + "/upgrade')" }
				data-indicator:upgrading
				data-attr:disabled="$upgrading"
			>
				<span data-show="!$upgrading">Upgrade to Pro</span>
				<span class="spinner" data-show="$upgrading" style="display:none" aria-hidden="true"></span>
			</button>
			<span class="hint">Secure checkout via Stripe — you'll confirm payment on Stripe, then land back here. Cancel anytime.</span>
		</div>
	</section>
}

// ManageCard is the counterpart to UpgradeCard, shown to an admin of a workspace
// already on a paid plan (gated by ProjectVM.CanManage; the server re-checks on
// POST). It reads as a settled/active state — a brass accent and a live status dot
// rather than the ember "buy now" urgency — and its one action hands the browser to
// the provider's hosted customer portal to update payment, view invoices, or cancel.
// $managing drives the in-flight spinner/disabled state so a double-click can't open
// two sessions. The actual plan change from any cancellation is webhook-driven.
templ ManageCard(p ProjectVM) {
	<section class="card manage-card" aria-labelledby="manage-h" data-signals="{managing:false}">
		<p class="eyebrow">Plan</p>
		<h2 id="manage-h">Manage your plan</h2>
		<p class="manage-status"><span class="dot" aria-hidden="true"></span>{ p.PlanName } — active</p>
		<p class="manage-lede">
			Update your payment method, download invoices, or cancel your subscription —
			anytime, in the secure billing portal.
		</p>
		<div class="manage-actions">
			<button
				class="btn btn-primary"
				data-on:click={ "@post('/projects/" + p.TeamID + "/billing/manage')" }
				data-indicator:managing
				data-attr:disabled="$managing"
			>
				<span data-show="!$managing">Manage subscription</span>
				<span class="spinner" data-show="$managing" style="display:none" aria-hidden="true"></span>
			</button>
			<span class="hint">Opens the billing portal in this tab. A cancellation stays active until the end of the period you've paid for.</span>
		</div>
	</section>
}

// MigrateCard is the one-time onboarding action: bring an existing local
// mempalace into this workspace. It is intentionally instructional (a copy-paste
// command) rather than a server-side upload — the migration vehicle is a CLI that
// reads the user's local palace and streams it to /import, so the dashboard's job
// is to hand over the exact, correct command. The card carries no secret: the
// token in the command is a placeholder, and the real key stays behind the
// admin-gated Reveal in the API-key block. The copy button is the only
// interactive part, so this stays a cheap static section with one data-on:click.
templ MigrateCard(serverBase string) {
	<section class="card migrate" aria-labelledby="migrate-h" data-signals="{migrateCopied: false}">
		<p class="eyebrow">Migrate</p>
		<h2 id="migrate-h">Bring your mempalace</h2>
		<p class="migrate-lede">
			Move an existing local <span class="mono">mempalace</span> into this workspace —
			every drawer, diary entry, closet, knowledge-graph fact and tunnel. The
			server re-embeds each memory with its own model, and your local palace is
			only ever read.
		</p>
		<div class="kv">Run where mempalace is installed</div>
		<pre class="cmd" aria-label="Migration command"><code>{ MigrateCommand(serverBase) }</code></pre>
		<div class="cmd-actions">
			<button
				class="btn btn-ghost btn-sm"
				type="button"
				data-on:click={ copyExpr(MigrateCommand(serverBase)) + "; $migrateCopied = true" }
			>
				<span data-show="!$migrateCopied">Copy command</span>
				<span data-show="$migrateCopied" style="display:none">Copied ✓</span>
			</button>
			<span class="cmd-hint">
				Swap in this project's API key (<b>Reveal</b> it above). The exporter is
				<span class="mono">clients/migrate/mempalace_export.py</span>; add
				<span class="mono">--out palace.ndjson</span> to inspect the bundle first.
			</span>
		</div>
	</section>
}

// SkillEditor is the create/update form. It is one surface for both: saving a new
// name creates a skill; saving an existing name overwrites it and bumps the
// version (skill.Service.Update is an upsert). The Save button is disabled while
// a request is in flight (data-indicator:saving) and until both required fields
// are non-blank, so the server never receives an empty payload from the happy
// path. The body uses a monospaced textarea because a skill is a SKILL.md.
templ SkillEditor(teamID string) {
	<div class="card editor">
		<p class="eyebrow">New or updated skill</p>
		<div class="field">
			<label for="skillName">Name</label>
			<input
				class="input"
				id="skillName"
				data-bind:skill-name
				placeholder="e.g. code-review"
				autocomplete="off"
				spellcheck="false"
			/>
		</div>
		<div class="field">
			<label for="skillDescription">Description <span class="opt">optional</span></label>
			<input
				class="input"
				id="skillDescription"
				data-bind:skill-description
				placeholder="One line: what this skill is for"
			/>
		</div>
		<div class="field">
			<label for="skillContent">Body</label>
			<textarea
				class="textarea"
				id="skillContent"
				data-bind:skill-content
				placeholder="The SKILL.md body your agents load…"
				rows="12"
				spellcheck="false"
			></textarea>
		</div>
		<div class="editor-actions">
			<button
				class="btn btn-primary"
				data-on:click={ "@post('/projects/" + teamID + "/skills')" }
				data-indicator:saving
				data-attr:disabled="$saving || $skillName === '' || $skillContent === ''"
			>
				<span data-show="!$saving">Save skill</span>
				<span class="spinner" data-show="$saving" style="display:none" aria-hidden="true"></span>
			</button>
			<button
				class="btn btn-ghost"
				type="button"
				data-on:click="$skillName=''; $skillDescription=''; $skillContent=''"
			>Clear</button>
			<span class="hint" data-show="$skillName !== ''" style="display:none">
				Saving as <span class="mono" data-text="$skillName"></span> — an existing name updates and bumps its version.
			</span>
		</div>
	</div>
}

// SkillsList is the morph target (id="skills") the create/update handler patches.
// The patched fragment carries the id itself so datastar replaces this exact
// node. The count header lives inside so it refreshes with the list.
templ SkillsList(p ProjectVM, skills []SkillVM, canWrite bool) {
	<div id="skills" class="skills-section">
		<div class="skills-head">
			<h2>Published skills</h2>
			<span class="count">{ strconv.Itoa(len(skills)) }</span>
		</div>
		if len(skills) == 0 {
			<div class="card empty">
				<h3>No skills yet</h3>
				if canWrite {
					<p>Use the editor above to publish your first shared skill.</p>
				} else {
					<p>This workspace has not published any centralised skills.</p>
				}
			</div>
		} else {
			<div class="skills-list">
				for _, sk := range skills {
					@SkillRow(p, sk, canWrite)
				}
			</div>
		}
	</div>
}

// SkillRow is one skill's metadata card. The Edit button (writers only) seeds the
// editor signals from this row and fetches the body into it; the body is not in
// the list payload, so editing always loads the freshest stored content.
templ SkillRow(p ProjectVM, sk SkillVM, canWrite bool) {
	<article class="skill card">
		<div class="skill-top">
			<div class="skill-id">
				<h3 class="skill-name">{ sk.Name }</h3>
				<span class="badge">{ versionBadge(sk) }</span>
			</div>
			if canWrite {
				<button
					class="btn btn-ghost btn-sm"
					type="button"
					data-on:click={ editExpr(p.TeamID, sk) }
					aria-label={ "Edit skill " + sk.Name }
				>Edit</button>
			}
		</div>
		if sk.Description != "" {
			<p class="skill-desc">{ sk.Description }</p>
		}
		<div class="skill-meta">{ skillMeta(sk) }</div>
	</article>
}

// ShareCard is the outgoing push form: copy one of THIS workspace's wings into
// another, named by its slug. It is datastar-driven — the wing <select> and the
// slug input bind to page signals that post to /share, and the server streams
// back a flash + cleared inputs. It copies nothing on its own: filing the request
// only asks; the destination admin's Accept (see IncomingShares) runs the copy.
// Rendered only for writers/admins (the page gates on CanShare); the server
// re-checks regardless. The empty state guides a workspace that has no wings yet.
templ ShareCard(d ShareData) {
	<section class="card share-card" aria-labelledby="share-h" data-signals="{shareWing:'', shareSlug:''}">
		<p class="eyebrow">Share</p>
		<h2 id="share-h">Share a wing</h2>
		<p class="share-lede">
			Copy one of this workspace's wings into another workspace. Nothing leaves
			until an <b>admin</b> of the destination accepts the request — so a slug
			alone never moves your memory.
		</p>
		if len(d.Wings) == 0 {
			<div class="note" role="note">
				No wings to share yet — file some memory into this workspace first, then
				it can be shared.
			</div>
		} else {
			<div class="share-grid">
				<div class="field">
					<label for="shareWing">Wing</label>
					<select class="input" id="shareWing" data-bind:share-wing>
						<option value="">Choose a wing…</option>
						for _, wg := range d.Wings {
							<option value={ wg.Name }>{ shareWingOption(wg) }</option>
						}
					</select>
				</div>
				<div class="field">
					<label for="shareSlug">Destination workspace slug</label>
					<input
						class="input"
						id="shareSlug"
						data-bind:share-slug
						placeholder="e.g. acme-team-9f2c1a"
						autocomplete="off"
						spellcheck="false"
						data-on:keydown={ "evt.key === 'Enter' && $shareWing !== '' && $shareSlug.trim() !== '' && @post('/projects/" + d.TeamID + "/share')" }
					/>
				</div>
			</div>
			<div class="share-actions">
				<button
					class="btn btn-primary"
					data-on:click={ "@post('/projects/" + d.TeamID + "/share')" }
					data-indicator:sharing
					data-attr:disabled="$sharing || $shareWing === '' || $shareSlug.trim() === ''"
				>
					<span data-show="!$sharing">Request share</span>
					<span class="spinner" data-show="$sharing" style="display:none" aria-hidden="true"></span>
				</button>
				<span class="hint">
					Ask the destination's owner for their workspace slug — they copy it
					in one click from the <b>slug</b> chip under their workspace name
					(on the dashboard or its project page).
				</span>
			</div>
		}
	</section>
}

// IncomingShares is the destination admin's inbox: pending requests from other
// workspaces to copy a wing into this one. Its root carries the stable
// id="incoming-shares" so the accept/decline handlers can morph it with the
// refreshed list. A shared, frontend-only _resolving signal (the _ keeps it off
// the wire) drives one "Working…" line and disables the buttons while a copy is in
// flight — data-indicator auto-resets it on completion, success or error, so it
// never sticks. Rendered only for admins (the page gates on IsAdmin).
templ IncomingShares(d ShareData) {
	<section id="incoming-shares" class="share-inbox" aria-labelledby="inbox-h" data-signals="{_resolving:false}">
		<div class="skills-head">
			<h2 id="inbox-h">Incoming share requests</h2>
			<span class="count">{ strconv.Itoa(len(d.Incoming)) }</span>
		</div>
		<div class="share-working" data-show="$_resolving" style="display:none" role="status">Working…</div>
		if len(d.Incoming) == 0 {
			<div class="card empty">
				<h3>No pending requests</h3>
				<p>When another workspace asks to share a wing into this one, it appears here for you to accept or decline.</p>
			</div>
		} else {
			<div class="share-req-list">
				for _, req := range d.Incoming {
					@ShareRequestRow(d.TeamID, req)
				}
			</div>
		}
	</section>
}

// ShareRequestRow is one pending incoming request with its provenance and the
// Accept/Decline actions. Accept runs palace.CopyWing on the server; Decline just
// resolves the row. Both post to a request-scoped path (the id is a server-minted
// uuid, safe to embed) and share the inbox's _resolving indicator.
templ ShareRequestRow(teamID string, req ShareReqVM) {
	<article class="card share-req">
		<div class="share-req-main">
			<h3 class="share-req-wing">{ req.Wing }</h3>
			<p class="share-req-meta">
				from <b>{ shareReqFrom(req) }</b>
				if req.Requester != "" {
					{ " · requested by " }{ req.Requester }
				}
				if shareReqWhen(req) != "" {
					{ " · " }{ shareReqWhen(req) }
				}
			</p>
		</div>
		<div class="share-req-actions">
			<button
				class="btn btn-primary btn-sm"
				data-on:click={ "@post('/projects/" + teamID + "/share/" + req.ID + "/accept')" }
				data-indicator:_resolving
				data-attr:disabled="$_resolving"
			>Accept</button>
			<button
				class="btn btn-ghost btn-sm"
				data-on:click={ "@post('/projects/" + teamID + "/share/" + req.ID + "/decline')" }
				data-indicator:_resolving
				data-attr:disabled="$_resolving"
			>Decline</button>
		</div>
	</article>
}

// MergeCard folds one wing into another to clean up duplicates (e.g. an import
// that left both wing_x and x). The merge + graph rebuild run as a background job,
// so the card just enqueues: auto-detected wing_X/X pairs offer a one-click merge,
// and the generic picker (source <select> -> target text+datalist) handles the
// rest. The target is free text so folding into a fresh name works as a rename.
// Rendered only for writers/admins (the page gates on CanManage); server re-checks.
templ MergeCard(d MergeData) {
	<section class="card merge-card" aria-labelledby="merge-h" data-signals="{mergeSource:'', mergeTarget:''}">
		<p class="eyebrow">Maintain</p>
		<h2 id="merge-h">Merge wings</h2>
		<p class="merge-lede">
			Fold one wing into another — useful when an import left duplicates like
			<span class="mono">wing_x</span> and <span class="mono">x</span>. The merge and
			graph rebuild run as a background job, so you can leave this page.
		</p>
		@MergeSuggestions(d)
		<div class="merge-grid">
			<div class="field">
				<label for="mergeSource">From wing</label>
				<select class="input" id="mergeSource" data-bind:merge-source>
					<option value="">Choose a wing…</option>
					for _, wname := range d.Wings {
						<option value={ wname }>{ wname }</option>
					}
				</select>
			</div>
			<div class="field">
				<label for="mergeTarget">Into wing</label>
				<input
					class="input"
					id="mergeTarget"
					list="merge-wing-list"
					data-bind:merge-target
					placeholder="existing or new wing name"
					autocomplete="off"
					spellcheck="false"
					data-on:keydown={ "evt.key === 'Enter' && $mergeSource !== '' && $mergeTarget.trim() !== '' && $mergeSource !== $mergeTarget && @post('/projects/" + d.TeamID + "/merges')" }
				/>
				<datalist id="merge-wing-list">
					for _, wname := range d.Wings {
						<option value={ wname }></option>
					}
				</datalist>
			</div>
		</div>
		<div class="merge-actions">
			<button
				class="btn btn-primary"
				data-on:click={ "@post('/projects/" + d.TeamID + "/merges')" }
				data-indicator:merging
				data-attr:disabled="$merging || $mergeSource === '' || $mergeTarget.trim() === '' || $mergeSource === $mergeTarget"
			>
				<span data-show="!$merging">Queue merge</span>
				<span class="spinner" data-show="$merging" style="display:none" aria-hidden="true"></span>
			</button>
			<span class="hint">Drawers and closets move into the target; ids and vectors are untouched.</span>
		</div>
		@MergeJobs(d)
	</section>
}

// MergeSuggestions is the auto-detected duplicate-pairs block and a morph target
// (id="merge-suggestions") the enqueue + poll handlers refresh — so once a merge
// finishes, the pair it resolved drops off rather than lingering as a stale
// "duplicate detected" prompt. Renders nothing visible when there are no pairs.
templ MergeSuggestions(d MergeData) {
	<div id="merge-suggestions">
		if len(d.Duplicates) > 0 {
			<div class="merge-dups">
				<div class="kv">Duplicate wings detected</div>
				for _, dup := range d.Duplicates {
					@MergeDupRow(d.TeamID, dup)
				}
			</div>
		}
	</div>
}

// MergeDupRow is one detected wing_X/X collision with a one-click merge. The
// button seeds the picker signals (so the form mirrors the action) and posts in
// one expression; names are JSON-encoded for safe embedding.
templ MergeDupRow(teamID string, dup MergeDupVM) {
	<div class="merge-dup">
		<span class="merge-dup-label">{ mergeDupLabel(dup) }</span>
		<button
			class="btn btn-ghost btn-sm"
			data-on:click={ "$mergeSource = " + jsString(dup.Source) + "; $mergeTarget = " + jsString(dup.Target) + "; @post('/projects/" + teamID + "/merges')" }
		>
			Merge into { dup.Target }
		</button>
	</div>
}

// MergeJobs is the recent-jobs panel and the morph target (id="merge-jobs") the
// enqueue + poll handlers patch. While any job is queued/running (Active), it
// renders a data-on-interval poller that re-fetches itself every 2s; once the
// worker finishes, the refreshed fragment omits the poller and polling stops.
templ MergeJobs(d MergeData) {
	<div id="merge-jobs" class="merge-jobs">
		if len(d.Jobs) > 0 {
			<div class="kv">Recent merges</div>
			<div class="merge-job-list">
				for _, j := range d.Jobs {
					@MergeJobRow(j)
				}
			</div>
		}
		if d.Active {
			<div
				data-on-interval__duration.2s={ "@get('/projects/" + d.TeamID + "/merges')" }
				aria-hidden="true"
			></div>
		}
	</div>
}

// MergeJobRow is one job: the wings it folds, its outcome summary (counts on done,
// the error on failed), a status badge, and the date.
templ MergeJobRow(j MergeJobVM) {
	<div class="merge-job">
		<div class="merge-job-main">
			<span class="merge-job-wings">{ j.Sources } → { j.Target }</span>
			if j.Summary != "" {
				<span class="merge-job-summary">{ j.Summary }</span>
			}
		</div>
		<div class="merge-job-side">
			<span class={ mergeJobStatusClass(j.Status) }>{ j.Status }</span>
			if j.When != "" {
				<span class="merge-job-when">{ j.When }</span>
			}
		</div>
	</div>
}

// MembersBlock renders the Members section: who belongs to this workspace, their
// roles, and — for an admin — the controls to add a registered user, change a
// role, or remove someone. It is the datastar morph target (id "members-<TeamID>")
// the add/role/remove handlers patch with the refreshed roster and an inline
// result. Every member has their own API key, so adding a person provisions their
// token and removing them revokes it — this list IS the workspace's access panel.
// data-signals__ifmissing seeds the add-form inputs without clobbering a
// half-typed email when the fragment re-morphs after an error. Non-admins see the
// roster read-only (no add form, role badges instead of selectors).
templ MembersBlock(d MembersVM) {
	<section id={ "members-" + d.TeamID } class="card members" aria-labelledby="members-h" data-signals__ifmissing="{memberEmail:'', memberRole:'member'}">
		<div class="skills-head">
			<h2 id="members-h">Members</h2>
			<span class="count">{ strconv.Itoa(len(d.Members)) }</span>
		</div>
		<p class="members-lede">
			Everyone here has their own API key. Add a teammate to give them their own
			token; remove them and it is revoked immediately — they can no longer connect.
		</p>
		if d.Notice != "" {
			<div class="members-msg ok" role="status">{ d.Notice }</div>
		}
		if d.Error != "" {
			<div class="members-msg err" role="alert">{ d.Error }</div>
		}
		if d.CanManage {
			@AddMemberForm(d.TeamID)
		}
		<div class="member-list">
			for _, m := range d.Members {
				@MemberRow(d.TeamID, m, d.CanManage)
			}
		</div>
	</section>
}

// AddMemberForm is the admin-only control to add a registered user by email with a
// starting role. It posts the memberEmail/memberRole signals; the server adds the
// membership, mints the member's own key, and patches the list. The person must
// already have an account — there are no email invitations — so the hint says so.
// Add is disabled while in flight and until an email is entered, so the happy path
// never sends an empty submit. Enter in the email field submits too.
templ AddMemberForm(teamID string) {
	<div class="member-add">
		<div class="member-add-grid">
			<div class="field">
				<label for="memberEmail">Add a member by email</label>
				<input
					class="input"
					id="memberEmail"
					type="email"
					data-bind:member-email
					placeholder="teammate@company.com"
					autocomplete="off"
					spellcheck="false"
					data-on:keydown={ "evt.key === 'Enter' && $memberEmail.trim() !== '' && @post('/projects/" + teamID + "/members')" }
				/>
			</div>
			<div class="field">
				<label for="memberRole">Role</label>
				<select class="input" id="memberRole" data-bind:member-role>
					<option value="member">Member — read-only</option>
					<option value="writer">Writer — edit skills</option>
					<option value="admin">Admin — manage members &amp; keys</option>
				</select>
			</div>
		</div>
		<div class="member-add-actions">
			<button
				class="btn btn-primary"
				data-on:click={ "@post('/projects/" + teamID + "/members')" }
				data-indicator:addingMember
				data-attr:disabled="$addingMember || $memberEmail.trim() === ''"
			>
				<span data-show="!$addingMember">Add member</span>
				<span class="spinner" data-show="$addingMember" style="display:none" aria-hidden="true"></span>
			</button>
			<span class="hint">They need an agentsmemory account already — ask them to sign up first, then add their email here.</span>
		</div>
	</div>
}

// MemberRow is one member: their identity and role, plus (for an admin) a role
// selector that posts on change and a Remove button. The signed-in member's own
// row is marked "you". Removing revokes that member's keys, so Remove carries a
// confirm; the server still guards the last admin. Non-admins see a static role
// badge only. The confirm message and the ids are safely embedded (email via
// jsString; team/user ids are server-minted UUIDs).
templ MemberRow(teamID string, m MemberVM, canManage bool) {
	<div class="member-row">
		<div class="member-main">
			<span class="member-name">
				{ memberName(m) }
				if m.IsSelf {
					<span class="member-you">you</span>
				}
			</span>
			if memberName(m) != m.Email {
				<span class="member-email">{ m.Email }</span>
			}
		</div>
		if canManage {
			<div class="member-actions">
				<select
					class="input member-role"
					aria-label={ "Role for " + m.Email }
					data-on:change={ "@post('/projects/" + teamID + "/members/" + m.UserID + "/role?role=' + evt.target.value)" }
				>
					@roleOption("member", m.Role)
					@roleOption("writer", m.Role)
					@roleOption("admin", m.Role)
				</select>
				<button
					class="btn btn-ghost btn-sm member-remove"
					aria-label={ "Remove " + m.Email }
					data-on:click={ "confirm(" + jsString("Remove "+m.Email+"? Their API key will be revoked and they will lose access.") + ") && @post('/projects/" + teamID + "/members/" + m.UserID + "/remove')" }
				>Remove</button>
			</div>
		} else {
			<span class={ memberRoleBadgeClass(m.Role) }>{ roleLabel(m.Role) }</span>
		}
	</div>
}

// roleOption renders one <option> for a member's role selector, marking the
// member's current role selected so the control opens on the right value.
templ roleOption(value string, current string) {
	<option value={ value } selected?={ value == current }>{ roleLabel(value) }</option>
}
