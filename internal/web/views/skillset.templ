package views

// SkillsetAdminPage is the platform-superadmin editor for the GLOBAL am_skillset
// wakeup playbook — the single document every tenant's agents receive. It mirrors
// the project skills page's shape (breadcrumb, page-head, flash, one editor card)
// so the admin surface feels like the rest of the dashboard, but it edits one
// global doc rather than a per-team list. The signal wrapper seeds both the bound
// content and a frontend-only original, so Revert and the unsaved-changes hint
// work with no round-trip.
templ SkillsetAdminPage(d SkillsetAdminData) {
	@Layout("Global skillset", d.UserEmail) {
		<nav class="breadcrumb" aria-label="Breadcrumb">
			<a href="/dashboard">← Dashboard</a>
		</nav>
		<section class="page-head">
			<p class="eyebrow">Platform · Superadmin</p>
			<h1>Global wakeup skillset</h1>
			<p>
				The playbook every agent receives from <span class="mono">am_skillset</span> — how to
				drive this server's tools, in what order, and which centralised skills to load.
				Edited here once; served to <b>every</b> workspace.
			</p>
			@SkillsetMeta(d)
		</section>
		@Flash(d.Flash)
		<div data-signals={ skillsetEditorSignals(d.Content) }>
			@SkillsetEditor(d.Content)
			<section class="card note" aria-label="How the skillset is delivered">
				<p class="eyebrow">How it reaches agents</p>
				<p>
					You write only the <b>guidance</b>. The live catalogue of every
					<span class="mono">am_*</span> tool is appended automatically, so the method
					list never drifts as tools change. A user installs one small
					<span class="mono">am.md</span> command that calls <span class="mono">am_skillset</span>
					on wake-up and follows what it returns.
				</p>
			</section>
		</div>
	}
}

// SkillsetMeta is the version/provenance line under the heading. It carries the
// stable id="skillset-meta" so the save handler can morph just this fragment with
// the new version, leaving the editor untouched.
templ SkillsetMeta(d SkillsetAdminData) {
	<div id="skillset-meta" class="meta-row">
		<span class="badge">{ skillsetVersionLabel(d) }</span>
		if d.UpdatedBy != "" {
			<span class="slug">last edited by { d.UpdatedBy }</span>
		}
	</div>
}

// SkillsetEditor is the single-textarea editor for the playbook body. The body is
// rendered into the textarea (so it is visible before datastar hydrates) and bound
// to $skillsetContent. Save posts the signal; it is disabled while a request is in
// flight, when the body is blank, and when nothing has changed since load — so the
// server never receives an empty or no-op write. Revert restores the original, and
// the hint announces unsaved changes.
templ SkillsetEditor(content string) {
	<div class="card editor">
		<div class="field">
			<label for="skillsetContent">Wakeup playbook</label>
			<textarea
				class="textarea mono"
				id="skillsetContent"
				data-bind:skillset-content
				rows="22"
				spellcheck="false"
				aria-describedby="skillset-help"
			>{ content }</textarea>
			<p id="skillset-help" class="hint" style="display:block">
				Markdown. Describe the wake-up order and which skills to load — keep it short; agents read it every session.
			</p>
		</div>
		<div class="editor-actions">
			<button
				class="btn btn-primary"
				data-on:click="@post('/superadmin/skillset')"
				data-indicator:saving
				data-attr:disabled="$saving || $skillsetContent.trim() === '' || $skillsetContent === $_skillsetOriginal"
			>
				<span data-show="!$saving">Save playbook</span>
				<span class="spinner" data-show="$saving" style="display:none" aria-hidden="true"></span>
			</button>
			<button
				class="btn btn-ghost"
				type="button"
				data-attr:disabled="$skillsetContent === $_skillsetOriginal"
				data-on:click="$skillsetContent = $_skillsetOriginal"
			>Revert</button>
			<span class="hint" data-show="$skillsetContent !== $_skillsetOriginal" style="display:none">
				Unsaved changes — Save publishes a new version to every workspace.
			</span>
		</div>
	</div>
}
