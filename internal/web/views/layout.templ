package views

// Layout is the shared HTML shell: fonts, the embedded stylesheet, the datastar
// runtime (v1.0.2, matching the datastar-go SDK), a sticky top bar, and a slot
// for page content. userEmail is empty for logged-out pages, which hides the
// account area.
templ Layout(title string, userEmail string) {
	<!DOCTYPE html>
	<html lang="en">
		<head>
			<meta charset="utf-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1"/>
			<title>{ title } · agentsmemory</title>
			<link rel="preconnect" href="https://fonts.googleapis.com"/>
			<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
			<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600&family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@400;500;600&display=swap" rel="stylesheet"/>
			<link rel="stylesheet" href={ templ.SafeURL(staticURL("/static/app.css")) }/>
			<script type="module" src="https://cdn.jsdelivr.net/gh/starfederation/datastar@v1.0.2/bundles/datastar.js"></script>
			// The passkey bridge: the only bespoke JS. It exposes window.pkRegister /
			// pkAuthenticate for the data-effect triggers, calls navigator.credentials,
			// and reports back via custom events. Deferred so it is ready before use.
			<script src={ templ.SafeURL(staticURL("/static/passkey.js")) } defer></script>
		</head>
		<body>
			<header class="topbar">
				<div class="wrap">
					<a class="brand" href="/" aria-label="AI Agent Memory — home">ai<b>agent</b>memory<span class="dot">.</span></a>
					if userEmail != "" {
						<div class="user">
							// Account & security link: the shield icon (not a bare email) makes
							// it read as the settings entry — this is where 2FA and passkeys live.
							<a class="user-account" href="/account" title="Account & security">
								@shieldIcon()
								<span class="email">{ userEmail }</span>
							</a>
							<form method="post" action="/logout">
								<button class="btn btn-ghost" type="submit">Sign out</button>
							</form>
						</div>
					}
				</div>
			</header>
			<main class="wrap">
				{ children... }
			</main>
			<footer>
				<div class="wrap">agentsmemory — memory for agents, served over MCP.</div>
			</footer>
		</body>
	</html>
}

// shieldIcon is a small inline shield-check glyph for the account/security link —
// an SVG (not an emoji) inheriting currentColor, per the icon guidelines.
templ shieldIcon() {
	<svg class="user-ico" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
		<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"></path>
		<path d="m9 12 2 2 4-4"></path>
	</svg>
}
