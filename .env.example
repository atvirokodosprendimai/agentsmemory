# agentsmemory configuration — copy to .env and fill in.
# Real environment variables always override values from .env.

# --- OAuth 2.1 (MCP, for the claude.ai remote connector) ---
# Issuer = the PUBLIC base URL of this server, no trailing slash, no /mcp.
# In production this must be the external https URL.
OAUTH_ISSUER=http://localhost:8080
# Stable secret that seals OAuth access/refresh tokens. Changing it invalidates
# every issued token. Generate one with:  openssl rand -hex 32
OAUTH_SECRET_KEY=

# --- Dashboard session cookie ---
# Signing key for the login session cookie, hex of >= 32 bytes.
# Generate with:  openssl rand -hex 32
AGENTSMEMORY_SESSION_KEY=

# --- API key reveal secret ---
# Seals workspace API keys at rest so the dashboard can reveal them after creation.
# Set it (32+ random chars) to keep keys revealable across restarts; unset uses a
# random per-boot key, so keys minted before a restart become reveal-unavailable.
# Generate with:  openssl rand -hex 32
AGENTSMEMORY_TOKEN_KEY=

# --- Social login (optional; goth) ---
# Only providers whose KEY/SECRET are set appear on the login page.
# PUBLIC_BASE_URL builds the OAuth callback URLs ({base}/auth/{provider}/callback).
PUBLIC_BASE_URL=http://localhost:8080
# GITHUB_KEY=
# GITHUB_SECRET=
# GOOGLE_KEY=
# GOOGLE_SECRET=
# FACEBOOK_KEY=
# FACEBOOK_SECRET=

# --- Platform superadmin (optional) ---
# Comma-separated emails allowed to edit the GLOBAL am_skillset wakeup playbook
# that every tenant shares (the only god-mode surface). Matched case-insensitively
# against the signed-in user's email. CLI flag --superadmin-emails overrides this.
# Empty (default) = no superadmin: the global skillset can still be seeded on a
# fresh database, just not edited from the dashboard.
# SUPERADMIN_EMAILS=you@example.com,colleague@example.com

# --- Billing (subscriptions: Pro monthly €50 / annual €500) ---
# Optional, and single-provider per deployment. Pick ONE backend with
# BILLING_PROVIDER; only that provider's keys need values. With the active
# provider's credentials unset, billing is inert and the dashboard shows no
# upgrade button. The plan catalog (€50/mo, €500/yr, EUR) is seeded by migration —
# only the provider's price/product ids (which differ test vs live) live here.
# BILLING_PROVIDER=stripe            # stripe (default) | polar

# Stripe (BILLING_PROVIDER=stripe): secret key + webhook signing secret, plus the
# Stripe Price id backing each plan.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_PRO_MONTHLY=
# STRIPE_PRICE_PRO_ANNUAL=

# Polar (BILLING_PROVIDER=polar): a Merchant of Record — it handles EU VAT for you.
#   POLAR_ACCESS_TOKEN         Organization Access Token — Polar dashboard →
#                              Settings → General → Developers → New Token.
#   POLAR_WEBHOOK_SECRET       Webhook signing secret — Settings → Webhooks → add an
#                              endpoint at {PUBLIC_BASE_URL}/webhooks/polar, then
#                              copy its secret (Standard-Webhooks / HMAC).
#   POLAR_PRODUCT_PRO_MONTHLY  Product id of the €50/month recurring product.
#   POLAR_PRODUCT_PRO_ANNUAL   Product id of the €500/year recurring product.
#   POLAR_SERVER               sandbox (default; sandbox-api.polar.sh) | production.
# POLAR_ACCESS_TOKEN=
# POLAR_WEBHOOK_SECRET=
# POLAR_PRODUCT_PRO_MONTHLY=
# POLAR_PRODUCT_PRO_ANNUAL=
# POLAR_SERVER=sandbox

# --- Server ---
# HTTP listen address and SQLite database path. CLI flags --addr / --db override
# these; both fall back to the built-in defaults when unset.
AGENTSMEMORY_ADDR=:8080
AGENTSMEMORY_DB=agentsmemory.db
# Verbose logging: per-request HTTP access logs (chi) + gorm SQL. Off by default
# (the server is intentionally quiet); set true to see traffic during dev.
# Overridable with --debug.
APP_DEBUG=false

# --- Read-only `mcp` CLI (optional) ---
# An API key for the `agentsmemory mcp` subcommand so a local read resolves a
# tenant and meters like the HTTP path. Only the CLI reads it; the server does
# not. CLI flag --token overrides this. Leave unset unless you use that CLI.
# AGENTSMEMORY_TOKEN=

# --- Vector storage (SQLite source of truth + optional Qdrant search index) ---
# SQLite always stores every vector durably (the source of truth). VECTOR_BACKEND
# picks what answers search:
#   sqlite  — the SQLite store also serves search (brute force, no external
#             service); the easy default for local dev.
#   qdrant  — SQLite stays the source of truth and Qdrant is the search index.
VECTOR_BACKEND=sqlite
# Qdrant connection (only used when VECTOR_BACKEND=qdrant).
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=

# --- Embeddings (Ollama) ---
# Ollama server that turns drawer text into vectors. bge-m3 is 1024-dimensional.
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=bge-m3
